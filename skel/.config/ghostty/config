theme = Citruszest

# Font
font-family = Iosevka Term Slab
font-size = 13.0
alpha-blending = linear-corrected

# Cursor
cursor-style-blink = true

# Quick Terminal
quick-terminal-position = right
quick-terminal-animation-duration = 0.2
quick-terminal-autohide = false
quick-terminal-size = 35%
gtk-quick-terminal-layer = overlay
# KDE Plasma 5.27's GlobalShortcuts portal receives this but does not register it.
# Meta+Ctrl+Shift+X is handled by ghostty-quick-terminal.desktop via KGlobalAccel.
# keybind = global:ctrl+shift+super+x=toggle_quick_terminal

# Window and Pane
background-opacity = 0.93
background-opacity-cells = true
background-blur = 10
unfocused-split-opacity = 0.4
split-divider-color = #003399

# URL detection (Ghostty has built-in URL matching)
link-url = true

bell-features = no-system,title,no-attention
shell-integration-features = true
auto-update = download
auto-update-channel = tip
